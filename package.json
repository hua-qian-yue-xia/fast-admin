{
  "name": "aspen-nestjs-api",
  "version": "1.0.0",
  "description": "nest多模块快速开发系统",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "admin:dev": "tsc --noEmit -p apps/admin/biz/tsconfig.json && NODE_ENV=dev nest start @aspen-nestjs-api/admin-biz --debug --watch",
    "admin:build": "tsc --noEmit -p apps/admin/biz/tsconfig.json && NODE_ENV=prod nest build @aspen-nestjs-api/admin-biz"
  },
  "workspaces": {
    "packages": [
      "./apps/*",
      "./packages/*"
    ]
  },
  "dependencies": {
    "@blazity/nest-file-fastify": "^1.0.0",
    "@fastify/static": "^9.0.0",
    "@liaoliaots/nestjs-redis": "^10.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.24",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dayjs": "^1.11.21",
    "enum-plus": "^3.1.8",
    "es-toolkit": "^1.47.0",
    "fastify": "^5.2.1",
    "fs-extra": "^11.3.5",
    "ioredis": "^5.11.1",
    "ms": "^2.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0",
    "typeorm-naming-strategies": "^4.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/ms": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "8.48.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}